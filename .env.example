# Copy to .env.local and fill in the values.

# Supabase (server-only — service_role bypasses RLS, never expose to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth app (Settings → Developer settings → OAuth Apps)
GITHUB_ID=
GITHUB_SECRET=

# NextAuth
# generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
